---
import Base from "../layouts/Base.astro";
import countrySummaries from "../data/country_summaries.json";
import meta from "../data/aggregates_meta.json";
import foreignBackground from "../data/foreign_background.json";
import history from "../data/history.json";

interface Row {
  region_code: string;
  region_level: number;
  region_name: string | null;
  homicide_count: number | null;
  homicide_rate: number | null;
  violent_total_count: number | null;
  violent_total_rate: number | null;
  assault_count: number | null;
  assault_rate: number | null;
  robbery_count: number | null;
  robbery_rate: number | null;
  sexual_assault_count: number | null;
  sexual_assault_rate: number | null;
  population: number | null;
  period_start: string;
  period_end: string;
  source_url: string;
}
interface MetaRow {
  country: string;
  latest_period_end: string | null;
  retrieved_at: string | null;
  n_rows: number;
  n_regions: number;
  authority: string;
}
interface FBRow {
  region_code: string;
  crime_category: string;
  total: number | null;
  national: number | null;
  foreign: number | null;
  foreign_share_pct: number | null;
}

const summaries = countrySummaries as Record<string, Row[]>;
const metaRows = meta as MetaRow[];
const fbData = foreignBackground as Record<string, FBRow[]>;
const historyData = history as Record<string, Record<string, Record<string, { count: number | null; rate: number | null }>>>;

// Year range for the time slider.
const allYears: number[] = [];
for (const region of Object.values(historyData)) {
  for (const yr of Object.keys(region)) allYears.push(parseInt(yr));
}
const minYear = allYears.length ? Math.min(...allYears) : 2024;
const maxYear = allYears.length ? Math.max(...allYears) : 2024;

const nf = new Intl.NumberFormat("en-GB");
const rateFmt = new Intl.NumberFormat("en-GB", { maximumFractionDigits: 2 });

const ukRows = summaries["UK"] ?? [];
const frRows = (summaries["FR"] ?? []).slice(0, 15);
const fbDE = fbData["DE"] ?? [];

function periodLabel(period_end: string | undefined | null): string {
  if (!period_end) return "—";
  const d = period_end.split("T")[0];
  return new Date(d).toLocaleDateString("en-GB", { month: "long", year: "numeric" });
}

const mvpStatus = [
  { iso: "UK", name: "United Kingdom", authority: "ONS", status: "live" },
  { iso: "FR", name: "France", authority: "SSMSI Interstats", status: "live" },
  { iso: "IT", name: "Italy", authority: "ISTAT", status: "live" },
  { iso: "DE", name: "Germany", authority: "BKA PKS Zeitreihen + Land", status: "live" },
  { iso: "SE", name: "Sweden", authority: "BRÅ Anmälda brott", status: "live" },
  { iso: "ES", name: "Spain", authority: "Min. Interior SEC", status: "live" },
  { iso: "DK", name: "Denmark", authority: "Danmarks Statistik (STRAF11)", status: "live" },
  { iso: "IE", name: "Ireland", authority: "CSO (CJA01)", status: "live" },
  { iso: "NL", name: "Netherlands", authority: "CBS 83648NED", status: "live" },
  { iso: "AT", name: "Austria", authority: "BMI Kriminalstatistik", status: "scaffolded" },
  { iso: "BE", name: "Belgium", authority: "Federal Police", status: "scaffolded" },
  { iso: "PT", name: "Portugal", authority: "INE", status: "scaffolded" },
];
---
<Base>
  <section class="px-4 sm:px-6 py-10 sm:py-12 max-w-3xl mx-auto">
    <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold mb-4">The Great Stabbing</h1>
    <p class="text-base sm:text-lg text-stone mb-6">
      A Europe-wide map of violent crime — stabbings, shootings, fatal beatings — pulled
      from each country's official police and statistical authorities, and from regional
      news media. Inspired by
      <a href="https://hoyodecrimen.com">hoyodecrimen.com</a>.
    </p>
    <p class="text-stone mb-6 text-sm">
      <strong>Status:</strong> 6 of 6 MVP countries live. The choropleth shades regions by
      the metric you pick. The time slider scrubs through history where available.
      Red dots are news-extracted incidents; click to read the source quote.
    </p>
  </section>

  <section class="px-4 sm:px-6 max-w-6xl mx-auto">
    <div class="mb-3 flex flex-col sm:flex-row sm:flex-wrap items-start sm:items-center gap-3 sm:justify-between">
      <div class="flex flex-wrap items-center gap-2">
        <label for="metric-select" class="text-sm font-medium text-ink">Metric:</label>
        <select id="metric-select" aria-label="Choose which metric the choropleth shades by"
          class="bg-bone border border-ink/20 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-rust/40">
          <option value="homicide" selected>Homicide rate / 100k</option>
          <option value="assault_serious">Serious assault rate / 100k</option>
          <option value="robbery_violent">Violent robbery rate / 100k</option>
          <option value="sexual_assault">Sexual assault rate / 100k</option>
          <option value="violent_total">Violent total rate / 100k</option>
        </select>
        <label class="text-sm text-stone ml-3 flex items-center gap-1.5 cursor-pointer">
          <input id="show-pins" type="checkbox" checked aria-label="Toggle news-extracted incident pins" />
          news pins
        </label>
      </div>
      <div class="text-xs text-stone">Grey: no data for that metric / year.</div>
    </div>
    <div class="relative">
      <div id="map" role="region" aria-label="Choropleth map of Europe shaded by violent crime rate"
        class="h-[60vh] sm:h-[70vh] w-full rounded-lg border border-ink/10 bg-bone touch-pan-y"></div>
      <div id="map-legend" class="absolute bottom-3 left-3 bg-bone/95 backdrop-blur p-3 rounded border border-ink/10 text-xs pointer-events-none">
        <div class="font-medium mb-1" id="legend-title">Homicides / 100k / year</div>
        <div id="legend-bar" class="flex items-center space-x-1" aria-hidden="true"></div>
        <div id="legend-labels" class="flex justify-between text-stone tabular-nums mt-1 w-[160px]" aria-hidden="true"></div>
      </div>
    </div>
    {/* Time slider */}
    <div class="mt-4 flex flex-col sm:flex-row sm:items-center gap-3">
      <label for="year-slider" class="text-sm font-medium whitespace-nowrap">
        Year: <span id="year-label" class="tabular-nums">{maxYear}</span>
      </label>
      <input id="year-slider" type="range" min={minYear} max={maxYear} value={maxYear} step="1"
        aria-label="Choose which year of data the map displays"
        class="w-full accent-rust" />
      <div class="text-xs text-stone tabular-nums whitespace-nowrap">
        {minYear} — {maxYear}
      </div>
    </div>
    <p class="text-xs text-stone mt-2">
      Map base: OpenStreetMap. Region boundaries: Eurostat NUTS 2021 (03M).
      Mixed granularity per source. Some countries only publish current-year data;
      others (FR / IT / ES) carry 10 years of history.
    </p>
  </section>

  <!-- MVP status -->
  <section class="px-4 sm:px-6 py-12 max-w-4xl mx-auto">
    <h2 class="text-2xl font-semibold mb-4">MVP country status</h2>
    <div class="overflow-x-auto rounded-lg border border-ink/10">
      <table class="w-full text-sm">
        <thead class="bg-ink/5 text-left">
          <tr>
            <th class="px-3 py-2 font-medium">Country</th>
            <th class="px-3 py-2 font-medium">Source</th>
            <th class="px-3 py-2 font-medium">Status</th>
            <th class="px-3 py-2 font-medium text-right">Rows</th>
            <th class="px-3 py-2 font-medium text-right">Regions</th>
            <th class="px-3 py-2 font-medium">Latest period</th>
          </tr>
        </thead>
        <tbody>
          {mvpStatus.map((c) => {
            const m = metaRows.find((r) => r.country === c.iso);
            return (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2 font-medium">
                  <a href={`/country/${c.iso}`}>{c.name}</a>
                  <span class="text-xs text-stone ml-1">({c.iso})</span>
                </td>
                <td class="px-3 py-2 text-stone">{c.authority}</td>
                <td class="px-3 py-2">
                  <span class="inline-block px-2 py-0.5 rounded bg-rust/10 text-rust text-xs font-medium">LIVE</span>
                </td>
                <td class="px-3 py-2 text-right tabular-nums">{m ? nf.format(m.n_rows) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{m ? nf.format(m.n_regions) : "—"}</td>
                <td class="px-3 py-2 text-stone text-xs">{m ? periodLabel(m.latest_period_end ?? undefined) : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  {/* Foreign-background panel */}
  {fbDE.length > 0 && (
    <section class="px-4 sm:px-6 pb-12 max-w-4xl mx-auto">
      <h2 class="text-2xl font-semibold mb-2">Germany — foreign-suspect share <span class="text-sm font-normal text-stone">(Nichtdeutsche Tatverdächtige)</span></h2>
      <p class="text-stone text-sm mb-3">
        BKA's Polizeiliche Kriminalstatistik publishes a national/non-national split for
        Tatverdächtige (suspects). Suspects ≠ convictions, and not adjusted for age or sex.
        See <a href="/methodology">methodology</a> for the rules we follow.
      </p>
      <div class="overflow-x-auto rounded-lg border border-ink/10">
        <table class="w-full text-sm">
          <thead class="bg-ink/5 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Category</th>
              <th class="px-3 py-2 font-medium text-right">Total suspects</th>
              <th class="px-3 py-2 font-medium text-right">German</th>
              <th class="px-3 py-2 font-medium text-right">Non-German</th>
              <th class="px-3 py-2 font-medium text-right">Foreign share</th>
            </tr>
          </thead>
          <tbody>
            {fbDE.map((r) => (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2 font-medium">{r.crime_category.replace("_", " ")}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.total !== null ? nf.format(r.total) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.national !== null ? nf.format(r.national) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.foreign !== null ? nf.format(r.foreign) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums font-medium text-rust">{r.foreign_share_pct !== null ? `${r.foreign_share_pct}%` : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {/* UK + FR tables (collapsed in mobile) */}
  {ukRows.length > 0 && (
    <section class="px-4 sm:px-6 pb-12 max-w-4xl mx-auto">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="text-2xl font-semibold">UK — by NUTS-1 region</h2>
        <span class="text-xs text-stone">year ending {periodLabel(ukRows[0].period_end)}</span>
      </div>
      <div class="overflow-x-auto rounded-lg border border-ink/10">
        <table class="w-full text-sm">
          <thead class="bg-ink/5 text-left"><tr>
            <th class="px-3 py-2 font-medium">Region</th>
            <th class="px-3 py-2 font-medium text-right">Homicides</th>
            <th class="px-3 py-2 font-medium text-right">/ 100k</th>
            <th class="px-3 py-2 font-medium text-right">Violent total</th>
            <th class="px-3 py-2 font-medium text-right">/ 100k</th>
          </tr></thead>
          <tbody>
            {ukRows.map((r) => (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2">
                  <a href={`/region/${r.region_code}`} class="font-medium">{r.region_name ?? r.region_code}</a>
                </td>
                <td class="px-3 py-2 text-right tabular-nums">{r.homicide_count !== null ? nf.format(r.homicide_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums font-medium">{r.homicide_rate !== null ? rateFmt.format(r.homicide_rate) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.violent_total_count !== null ? nf.format(r.violent_total_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.violent_total_rate !== null ? rateFmt.format(r.violent_total_rate) : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</Base>

<script id="history-data" type="application/json" set:html={JSON.stringify(historyData)} />
<script id="year-bounds" type="application/json" set:html={JSON.stringify({minYear, maxYear})} />

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";

  const historyEl = document.getElementById("history-data");
  const yrEl = document.getElementById("year-bounds");
  const history: Record<string, Record<string, Record<string, { count: number | null; rate: number | null }>>> =
    historyEl ? JSON.parse(historyEl.textContent ?? "{}") : {};
  const { minYear, maxYear } = yrEl ? JSON.parse(yrEl.textContent ?? "{}") : { minYear: 2024, maxYear: 2024 };

  type Metric = "homicide" | "assault_serious" | "robbery_violent" | "sexual_assault" | "violent_total";

  const METRIC_CONFIG: Record<Metric, { label: string; legend: string; breaks: number[] }> = {
    homicide:        { label: "Homicide rate / 100k",        legend: "Homicides / 100k / year",        breaks: [0.5, 1, 2, 4] },
    assault_serious: { label: "Serious assault rate / 100k", legend: "Serious assaults / 100k / year", breaks: [50, 150, 300, 500] },
    robbery_violent: { label: "Violent robbery rate / 100k", legend: "Violent robbery / 100k / year",  breaks: [10, 30, 60, 100] },
    sexual_assault:  { label: "Sexual assault rate / 100k",  legend: "Sexual assault / 100k / year",   breaks: [10, 30, 60, 120] },
    violent_total:   { label: "Violent total rate / 100k",   legend: "Violent total / 100k / year",    breaks: [200, 600, 1200, 2000] },
  };
  const COLORS = ["#fef3e0", "#fbcfa5", "#f59557", "#d65f1c", "#9b2a2a"];

  let currentMetric: Metric = "homicide";
  let currentYear: number = maxYear;
  let regionsGeo: any = null;

  function valueFor(code: string, yr: number, metric: Metric): number | null {
    // Walk back up to 5 years to find data — countries publish at different cadences.
    for (let y = yr; y >= yr - 4; y--) {
      const entry = history[code]?.[String(y)]?.[metric];
      if (entry && entry.rate !== null && entry.rate !== undefined) return entry.rate;
    }
    return null;
  }

  function rebuildFeatures() {
    if (!regionsGeo) return;
    for (const f of regionsGeo.features) {
      const code = f.properties?.code as string | undefined;
      if (!code) continue;
      const v = valueFor(code, currentYear, currentMetric);
      f.properties.value = v;
    }
    const src = map.getSource("regions");
    if (src && (src as any).setData) (src as any).setData(regionsGeo);
  }

  function setLegend() {
    const cfg = METRIC_CONFIG[currentMetric];
    document.getElementById("legend-title")!.textContent = `${cfg.legend} — ${currentYear}`;
    const bar = document.getElementById("legend-bar")!;
    bar.innerHTML = "";
    for (const c of COLORS) {
      const span = document.createElement("span");
      span.className = "inline-block w-4 h-3";
      span.style.background = c;
      bar.appendChild(span);
    }
    const labels = document.getElementById("legend-labels")!;
    labels.innerHTML = "";
    const allLabels = ["0", ...cfg.breaks.map((b) => String(b)), `${cfg.breaks[cfg.breaks.length - 1]}+`];
    for (const t of allLabels) {
      const span = document.createElement("span");
      span.textContent = t;
      labels.appendChild(span);
    }
  }

  function fillExpression(): any {
    const cfg = METRIC_CONFIG[currentMetric];
    return [
      "step",
      ["coalesce", ["get", "value"], -1],
      "#e0e0e0", -1,
      COLORS[0], 0,
      COLORS[1], cfg.breaks[0],
      COLORS[2], cfg.breaks[1],
      COLORS[3], cfg.breaks[2],
      COLORS[4],
    ];
  }

  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      sources: {
        osm: { type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a>' },
      },
      layers: [{ id: "osm", type: "raster", source: "osm" }],
    },
    center: [10, 50],
    zoom: 3.5,
    maxZoom: 9,
  });
  map.addControl(new maplibregl.NavigationControl(), "top-right");

  map.on("load", async () => {
    const resp = await fetch("/data/regions.geojson");
    if (!resp.ok) return;
    regionsGeo = await resp.json();
    rebuildFeatures();

    map.addSource("regions", { type: "geojson", data: regionsGeo });
    map.addLayer({
      id: "region-fill", type: "fill", source: "regions",
      paint: { "fill-color": fillExpression(), "fill-opacity": 0.78 },
    });
    map.addLayer({
      id: "region-line", type: "line", source: "regions",
      paint: { "line-color": "#0f0f0f", "line-width": 0.4, "line-opacity": 0.6 },
    });

    // ----- Incidents source + clustering -----
    try {
      const ir = await fetch("/data/incidents.geojson");
      if (ir.ok) {
        const incidents = await ir.json();
        map.addSource("incidents", {
          type: "geojson",
          data: incidents,
          cluster: true,
          clusterMaxZoom: 9,
          clusterRadius: 40,
        });
        // Cluster circles
        map.addLayer({
          id: "incident-clusters",
          type: "circle",
          source: "incidents",
          filter: ["has", "point_count"],
          paint: {
            "circle-color": "#d65f1c",
            "circle-radius": [
              "step", ["get", "point_count"],
              14, 5, 18, 10, 22,
            ],
            "circle-stroke-color": "#0f0f0f",
            "circle-stroke-width": 1.2,
            "circle-opacity": 0.85,
          },
        });
        map.addLayer({
          id: "incident-cluster-count",
          type: "symbol",
          source: "incidents",
          filter: ["has", "point_count"],
          layout: {
            "text-field": ["get", "point_count_abbreviated"],
            "text-size": 12,
            "text-font": ["Noto Sans Regular"],
          },
          paint: { "text-color": "#0f0f0f" },
        });
        // Unclustered points
        map.addLayer({
          id: "incident-pins",
          type: "circle",
          source: "incidents",
          filter: ["!", ["has", "point_count"]],
          paint: {
            "circle-radius": ["interpolate", ["linear"], ["zoom"], 4, 4, 6, 6, 9, 9],
            "circle-color": [
              "case", [">", ["coalesce", ["get", "victim_fatal"], 0], 0],
              "#9b2a2a", "#d65f1c",
            ],
            "circle-stroke-color": "#0f0f0f", "circle-stroke-width": 1,
            "circle-opacity": [
              "case",
              ["==", ["get", "confidence"], "HIGH"], 0.95,
              ["==", ["get", "confidence"], "MEDIUM"], 0.85,
              0.7,
            ],
          },
        });
        const ipop = new maplibregl.Popup({ closeButton: true, closeOnClick: true, maxWidth: "320px" });
        map.on("click", "incident-pins", (e) => {
          const f = e.features?.[0];
          if (!f) return;
          const p = f.properties as any;
          let sources: any[] = [];
          try { sources = JSON.parse(p.sources ?? "[]"); } catch {}
          const sourceLinks = sources.length
            ? sources.map((s: any) => `<a href="${s.url}" target="_blank" rel="noopener noreferrer">${s.outlet ?? "source"}</a>`).join(", ")
            : "—";
          const quote = sources[0]?.quote_snippet ?? "";
          const fatalBadge = (p.victim_fatal ?? 0) > 0
            ? `<span style="color:#9b2a2a;font-weight:600">FATAL</span> · ` : "";
          const html = `
            <div style="font-family:Inter,system-ui;font-size:12px;line-height:1.45;max-width:300px">
              <div style="font-weight:600">${p.city || "(unknown)"} · ${p.country}</div>
              <div style="color:#6b6b6b;margin-bottom:6px">
                ${fatalBadge}weapon: ${p.weapon ?? "?"} · victims: ${p.victim_count ?? "?"} · conf: ${p.confidence ?? "?"}
              </div>
              ${quote ? `<div style="font-style:italic;color:#0f0f0f;border-left:3px solid #9b2a2a;padding-left:8px;margin:6px 0">${quote}</div>` : ""}
              ${p.date_incident ? `<div style="color:#6b6b6b">Incident: ${p.date_incident}</div>` : ""}
              <div style="color:#6b6b6b">Source: ${sourceLinks}</div>
            </div>`;
          ipop.setLngLat((f.geometry as any).coordinates).setHTML(html).addTo(map);
        });
        // Click cluster → zoom in
        map.on("click", "incident-clusters", (e) => {
          const features = map.queryRenderedFeatures(e.point, { layers: ["incident-clusters"] });
          const clusterId = features[0].properties?.cluster_id;
          const src = map.getSource("incidents") as any;
          src.getClusterExpansionZoom(clusterId, (err: any, zoom: number) => {
            if (err) return;
            map.easeTo({ center: (features[0].geometry as any).coordinates, zoom });
          });
        });
        map.on("mouseenter", "incident-pins", () => { map.getCanvas().style.cursor = "pointer"; });
        map.on("mouseleave", "incident-pins", () => { map.getCanvas().style.cursor = ""; });
        map.on("mouseenter", "incident-clusters", () => { map.getCanvas().style.cursor = "pointer"; });
        map.on("mouseleave", "incident-clusters", () => { map.getCanvas().style.cursor = ""; });
      }
    } catch {}

    // Region hover popup.
    const popup = new maplibregl.Popup({ closeButton: false, closeOnClick: false });
    map.on("mousemove", "region-fill", (e) => {
      const f = e.features?.[0];
      if (!f) return;
      const p = f.properties as any;
      const fmt = new Intl.NumberFormat("en-GB", { maximumFractionDigits: 2 });
      const cfg = METRIC_CONFIG[currentMetric];
      const v = p.value;
      const html = `
        <div style="font-family:Inter,system-ui;font-size:12px;line-height:1.4">
          <div style="font-weight:600">${p.name ?? p.code}</div>
          <div style="color:#6b6b6b">${p.country ?? "—"} · ${p.code} · ${currentYear}</div>
          <div style="margin-top:4px">
            ${cfg.label}: <b>${v !== null && v !== undefined ? fmt.format(v) : "—"}</b>
          </div>
        </div>`;
      map.getCanvas().style.cursor = "pointer";
      popup.setLngLat(e.lngLat).setHTML(html).addTo(map);
    });
    map.on("mouseleave", "region-fill", () => { map.getCanvas().style.cursor = ""; popup.remove(); });

    setLegend();
  });

  // Controls
  document.getElementById("metric-select")?.addEventListener("change", (e) => {
    currentMetric = (e.target as HTMLSelectElement).value as Metric;
    rebuildFeatures();
    if (map.getLayer("region-fill")) {
      map.setPaintProperty("region-fill", "fill-color", fillExpression());
    }
    setLegend();
  });
  document.getElementById("year-slider")?.addEventListener("input", (e) => {
    currentYear = parseInt((e.target as HTMLInputElement).value);
    document.getElementById("year-label")!.textContent = String(currentYear);
    rebuildFeatures();
    setLegend();
  });
  document.getElementById("show-pins")?.addEventListener("change", (e) => {
    const t = e.target as HTMLInputElement;
    const v = t.checked ? "visible" : "none";
    for (const id of ["incident-pins", "incident-clusters", "incident-cluster-count"]) {
      if (map.getLayer(id)) map.setLayoutProperty(id, "visibility", v);
    }
  });
</script>
