---
import Base from "../layouts/Base.astro";
import countrySummaries from "../data/country_summaries.json";
import meta from "../data/aggregates_meta.json";
import foreignBackground from "../data/foreign_background.json";

interface Row {
  region_code: string;
  region_level: number;
  region_name: string | null;
  homicide_count: number | null;
  homicide_rate: number | null;
  violent_total_count: number | null;
  violent_total_rate: number | null;
  assault_count: number | null;
  assault_rate: number | null;
  robbery_count: number | null;
  robbery_rate: number | null;
  sexual_assault_count: number | null;
  sexual_assault_rate: number | null;
  population: number | null;
  period_start: string;
  period_end: string;
  source_url: string;
}
interface MetaRow {
  country: string;
  latest_period_end: string | null;
  retrieved_at: string | null;
  n_rows: number;
  n_regions: number;
  authority: string;
}
interface FBRow {
  region_code: string;
  crime_category: string;
  total: number | null;
  national: number | null;
  foreign: number | null;
  foreign_share_pct: number | null;
  period_end: string | null;
}

const summaries = countrySummaries as Record<string, Row[]>;
const metaRows = meta as MetaRow[];
const fbData = foreignBackground as Record<string, FBRow[]>;

// region_code → all the per-metric data the client needs to drive the map.
const regionData: Record<string, {
  homicide_rate: number | null; homicide_count: number | null;
  assault_rate: number | null; assault_count: number | null;
  robbery_rate: number | null; robbery_count: number | null;
  sexual_assault_rate: number | null; sexual_assault_count: number | null;
  violent_total_rate: number | null; violent_total_count: number | null;
  region_name: string | null;
  country: string;
}> = {};
for (const country of Object.keys(summaries)) {
  for (const r of summaries[country]) {
    regionData[r.region_code] = {
      homicide_rate: r.homicide_rate,
      homicide_count: r.homicide_count,
      assault_rate: r.assault_rate,
      assault_count: r.assault_count,
      robbery_rate: r.robbery_rate,
      robbery_count: r.robbery_count,
      sexual_assault_rate: r.sexual_assault_rate,
      sexual_assault_count: r.sexual_assault_count,
      violent_total_rate: r.violent_total_rate,
      violent_total_count: r.violent_total_count,
      region_name: r.region_name,
      country,
    };
  }
}

const nf = new Intl.NumberFormat("en-GB");
const rateFmt = new Intl.NumberFormat("en-GB", { maximumFractionDigits: 2 });

const ukRows = summaries["UK"] ?? [];
const frRows = (summaries["FR"] ?? []).slice(0, 15);
const deRows = summaries["DE"] ?? [];
const fbDE = fbData["DE"] ?? [];

function periodLabel(period_end: string | undefined): string {
  if (!period_end) return "—";
  const d = period_end.split("T")[0];
  return new Date(d).toLocaleDateString("en-GB", { month: "long", year: "numeric" });
}

const mvpStatus = [
  { iso: "UK", name: "United Kingdom", authority: "ONS", status: "live" },
  { iso: "FR", name: "France", authority: "SSMSI Interstats", status: "live" },
  { iso: "IT", name: "Italy", authority: "ISTAT", status: "live" },
  { iso: "DE", name: "Germany", authority: "BKA PKS Zeitreihen", status: "live" },
  { iso: "SE", name: "Sweden", authority: "BRÅ Anmälda brott", status: "live" },
  { iso: "ES", name: "Spain", authority: "Ministerio del Interior", status: "scaffolded" },
];
const liveCount = mvpStatus.filter((c) => c.status === "live").length;
---
<Base>
  <section class="px-6 py-12 max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-5xl font-semibold mb-4">The Great Stabbing</h1>
    <p class="text-lg text-stone mb-6">
      A Europe-wide map of violent crime — stabbings, shootings, fatal beatings — pulled
      from each country's official police and statistical authorities, and from regional
      news media. Inspired by
      <a href="https://hoyodecrimen.com">hoyodecrimen.com</a>.
    </p>
    <p class="text-stone mb-6 text-sm">
      <strong>Status:</strong> {liveCount} of 6 MVP countries live. The choropleth below
      shades regions by your chosen metric (rate per 100k per year). Red dots are
      individual news-extracted incidents from the past two months. See
      <a href="/methodology">methodology</a> for sources and caveats.
    </p>
  </section>

  <section class="px-6 max-w-6xl mx-auto">
    <div class="mb-3 flex flex-wrap items-center gap-3 justify-between">
      <div class="flex items-center gap-2">
        <label for="metric-select" class="text-sm font-medium text-ink">Metric:</label>
        <select id="metric-select" class="bg-bone border border-ink/20 rounded px-3 py-1.5 text-sm">
          <option value="homicide_rate" selected>Homicide rate / 100k</option>
          <option value="assault_rate">Serious assault rate / 100k</option>
          <option value="robbery_rate">Violent robbery rate / 100k</option>
          <option value="sexual_assault_rate">Sexual assault rate / 100k</option>
          <option value="violent_total_rate">Violent total rate / 100k</option>
        </select>
        <label class="text-sm text-stone ml-3 flex items-center gap-1.5">
          <input id="show-pins" type="checkbox" checked />
          show news pins
        </label>
      </div>
      <div class="text-xs text-stone">
        Grey regions: no data published for that metric.
      </div>
    </div>
    <div class="relative">
      <div id="map" class="h-[70vh] w-full rounded-lg border border-ink/10 bg-bone"></div>
      <div id="map-legend" class="absolute bottom-3 left-3 bg-bone/95 backdrop-blur p-3 rounded border border-ink/10 text-xs">
        <div class="font-medium mb-1" id="legend-title">Homicides / 100k / year</div>
        <div id="legend-bar" class="flex items-center space-x-1"></div>
        <div id="legend-labels" class="flex justify-between text-stone tabular-nums mt-1 w-[160px]"></div>
        <div class="text-stone mt-1 text-[10px]">Sources: per-country, see methodology</div>
      </div>
    </div>
    <p class="text-xs text-stone mt-2">
      Map base: OpenStreetMap. Region boundaries: Eurostat NUTS 2021 (03M).
      Mixed granularity — UK at NUTS-1, FR at NUTS-3, IT at NUTS-2, DE and SE at country level (NUTS-0).
      Hover for region details; click a red dot to read the source quote.
    </p>
  </section>

  <!-- MVP status -->
  <section class="px-6 py-12 max-w-4xl mx-auto">
    <h2 class="text-2xl font-semibold mb-4">MVP country status</h2>
    <div class="overflow-x-auto rounded-lg border border-ink/10">
      <table class="w-full text-sm">
        <thead class="bg-ink/5 text-left">
          <tr>
            <th class="px-3 py-2 font-medium">Country</th>
            <th class="px-3 py-2 font-medium">Source</th>
            <th class="px-3 py-2 font-medium">Status</th>
            <th class="px-3 py-2 font-medium text-right">Rows</th>
            <th class="px-3 py-2 font-medium text-right">Regions</th>
            <th class="px-3 py-2 font-medium">Latest period</th>
          </tr>
        </thead>
        <tbody>
          {mvpStatus.map((c) => {
            const m = metaRows.find((r) => r.country === c.iso);
            return (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2 font-medium">
                  <a href={`/country/${c.iso}`}>{c.name}</a>
                  <span class="text-xs text-stone ml-1">({c.iso})</span>
                </td>
                <td class="px-3 py-2 text-stone">{c.authority}</td>
                <td class="px-3 py-2">
                  {c.status === "live" ? (
                    <span class="inline-block px-2 py-0.5 rounded bg-rust/10 text-rust text-xs font-medium">LIVE</span>
                  ) : (
                    <span class="inline-block px-2 py-0.5 rounded bg-ink/10 text-stone text-xs font-medium">scaffolded</span>
                  )}
                </td>
                <td class="px-3 py-2 text-right tabular-nums">{m ? nf.format(m.n_rows) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{m ? nf.format(m.n_regions) : "—"}</td>
                <td class="px-3 py-2 text-stone text-xs">{m ? periodLabel(m.latest_period_end ?? undefined) : "—"}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- Foreign-background panel (DE — the headline) -->
  {fbDE.length > 0 && (
    <section class="px-6 pb-12 max-w-4xl mx-auto">
      <h2 class="text-2xl font-semibold mb-2">Germany — foreign-suspect share <span class="text-sm font-normal text-stone">(Nichtdeutsche Tatverdächtige)</span></h2>
      <p class="text-stone text-sm mb-3">
        BKA's Polizeiliche Kriminalstatistik publishes a national/non-national split for
        Tatverdächtige (suspects) — the dimension Germany is in the MVP for. Suspects ≠ convictions,
        and these are not adjusted for age or sex composition. See
        <a href="/methodology">methodology</a> for the strict rules we follow on this variable.
      </p>
      <div class="overflow-x-auto rounded-lg border border-ink/10">
        <table class="w-full text-sm">
          <thead class="bg-ink/5 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Category</th>
              <th class="px-3 py-2 font-medium text-right">Total suspects</th>
              <th class="px-3 py-2 font-medium text-right">German</th>
              <th class="px-3 py-2 font-medium text-right">Non-German</th>
              <th class="px-3 py-2 font-medium text-right">Foreign share</th>
            </tr>
          </thead>
          <tbody>
            {fbDE.map((r) => (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2 font-medium">{r.crime_category.replace("_", " ")}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.total !== null ? nf.format(r.total) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.national !== null ? nf.format(r.national) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.foreign !== null ? nf.format(r.foreign) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums font-medium text-rust">{r.foreign_share_pct !== null ? `${r.foreign_share_pct}%` : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-stone mt-3">
        Source: BKA PKS Zeitreihen — federal (NUTS-0) totals, year ending December 2024.
      </p>
    </section>
  )}

  <!-- UK table -->
  {ukRows.length > 0 && (
    <section class="px-6 pb-12 max-w-4xl mx-auto">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="text-2xl font-semibold">United Kingdom — homicide by NUTS-1 region</h2>
        <span class="text-xs text-stone">year ending {periodLabel(ukRows[0].period_end)}</span>
      </div>
      <div class="overflow-x-auto rounded-lg border border-ink/10">
        <table class="w-full text-sm">
          <thead class="bg-ink/5 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Region</th>
              <th class="px-3 py-2 font-medium text-right">Homicides</th>
              <th class="px-3 py-2 font-medium text-right">Per 100k</th>
              <th class="px-3 py-2 font-medium text-right">Violent total</th>
              <th class="px-3 py-2 font-medium text-right">Per 100k</th>
              <th class="px-3 py-2 font-medium text-right text-stone">Population</th>
            </tr>
          </thead>
          <tbody>
            {ukRows.map((r) => (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2">
                  <a href={`/region/${r.region_code}`} class="font-medium">{r.region_name ?? r.region_code}</a>
                  <span class="text-xs text-stone ml-1">({r.region_code})</span>
                </td>
                <td class="px-3 py-2 text-right tabular-nums">{r.homicide_count !== null ? nf.format(r.homicide_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums font-medium">{r.homicide_rate !== null ? rateFmt.format(r.homicide_rate) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.violent_total_count !== null ? nf.format(r.violent_total_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.violent_total_rate !== null ? rateFmt.format(r.violent_total_rate) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums text-stone">{r.population !== null ? nf.format(r.population) : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  <!-- France top 15 -->
  {frRows.length > 0 && (
    <section class="px-6 pb-12 max-w-4xl mx-auto">
      <div class="flex items-baseline justify-between mb-4">
        <h2 class="text-2xl font-semibold">France — top 15 départements by homicide rate</h2>
        <span class="text-xs text-stone">year {periodLabel(frRows[0].period_end).split(" ").pop()}</span>
      </div>
      <div class="overflow-x-auto rounded-lg border border-ink/10">
        <table class="w-full text-sm">
          <thead class="bg-ink/5 text-left">
            <tr>
              <th class="px-3 py-2 font-medium">Département</th>
              <th class="px-3 py-2 font-medium text-right">Homicides</th>
              <th class="px-3 py-2 font-medium text-right">Per 100k</th>
              <th class="px-3 py-2 font-medium text-right">Assault</th>
              <th class="px-3 py-2 font-medium text-right">Per 100k</th>
              <th class="px-3 py-2 font-medium text-right text-stone">Population</th>
            </tr>
          </thead>
          <tbody>
            {frRows.map((r) => (
              <tr class="border-t border-ink/10 hover:bg-ink/5">
                <td class="px-3 py-2">
                  <a href={`/region/${r.region_code}`} class="font-medium">{r.region_name ?? r.region_code}</a>
                  <span class="text-xs text-stone ml-1">({r.region_code})</span>
                </td>
                <td class="px-3 py-2 text-right tabular-nums">{r.homicide_count !== null ? nf.format(r.homicide_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums font-medium">{r.homicide_rate !== null ? rateFmt.format(r.homicide_rate) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.assault_count !== null ? nf.format(r.assault_count) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums">{r.assault_rate !== null ? rateFmt.format(r.assault_rate) : "—"}</td>
                <td class="px-3 py-2 text-right tabular-nums text-stone">{r.population !== null ? nf.format(r.population) : "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</Base>

<!-- Lookups inlined as JSON islands so the map module reads them without re-fetching. -->
<script id="region-data" type="application/json" set:html={JSON.stringify(regionData)} />

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";

  const regionEl = document.getElementById("region-data");
  const regions: Record<string, any> = regionEl ? JSON.parse(regionEl.textContent ?? "{}") : {};

  type Metric =
    | "homicide_rate" | "assault_rate" | "robbery_rate"
    | "sexual_assault_rate" | "violent_total_rate";

  // Per-metric quintile-style breaks (chosen to avoid extreme outliers compressing
  // the scale). Values above the last break get the darkest band.
  const METRIC_CONFIG: Record<Metric, { label: string; legend: string; breaks: number[] }> = {
    homicide_rate:        { label: "Homicide rate / 100k",        legend: "Homicides / 100k / year",        breaks: [0.5, 1, 2, 4] },
    assault_rate:         { label: "Serious assault rate / 100k", legend: "Serious assaults / 100k / year", breaks: [50, 150, 300, 500] },
    robbery_rate:         { label: "Violent robbery rate / 100k", legend: "Violent robbery / 100k / year",  breaks: [10, 30, 60, 100] },
    sexual_assault_rate:  { label: "Sexual assault rate / 100k",  legend: "Sexual assault / 100k / year",   breaks: [10, 30, 60, 120] },
    violent_total_rate:   { label: "Violent total rate / 100k",   legend: "Violent total / 100k / year",    breaks: [200, 600, 1200, 2000] },
  };
  const COLORS = ["#fef3e0", "#fbcfa5", "#f59557", "#d65f1c", "#9b2a2a"]; // light → rust

  let currentMetric: Metric = "homicide_rate";

  const map = new maplibregl.Map({
    container: "map",
    style: {
      version: 8,
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> contributors',
        },
      },
      layers: [{ id: "osm", type: "raster", source: "osm" }],
    },
    center: [10, 50],
    zoom: 4,
    maxZoom: 9,
  });
  map.addControl(new maplibregl.NavigationControl(), "top-right");

  function setLegend(metric: Metric) {
    const cfg = METRIC_CONFIG[metric];
    document.getElementById("legend-title")!.textContent = cfg.legend;
    const bar = document.getElementById("legend-bar")!;
    bar.innerHTML = "";
    for (const c of COLORS) {
      const span = document.createElement("span");
      span.className = "inline-block w-4 h-3";
      span.style.background = c;
      bar.appendChild(span);
    }
    const labels = document.getElementById("legend-labels")!;
    labels.innerHTML = "";
    const allLabels = ["0", ...cfg.breaks.map((b) => String(b)), `${cfg.breaks[cfg.breaks.length - 1]}+`];
    for (const t of allLabels) {
      const span = document.createElement("span");
      span.textContent = t;
      labels.appendChild(span);
    }
  }

  function fillExpression(metric: Metric): any {
    const cfg = METRIC_CONFIG[metric];
    return [
      "step",
      ["coalesce", ["get", metric], -1],
      "#e0e0e0", -1,
      COLORS[0], 0,
      COLORS[1], cfg.breaks[0],
      COLORS[2], cfg.breaks[1],
      COLORS[3], cfg.breaks[2],
      COLORS[4],
    ];
  }

  map.on("load", async () => {
    const resp = await fetch("/data/regions.geojson");
    if (!resp.ok) {
      console.warn("regions.geojson not available", resp.status);
      return;
    }
    const geo = await resp.json();
    for (const f of geo.features) {
      const code = f.properties?.code as string | undefined;
      const hit = code ? regions[code] : null;
      f.properties = f.properties || {};
      if (hit) {
        f.properties.homicide_rate       = hit.homicide_rate;
        f.properties.assault_rate        = hit.assault_rate;
        f.properties.robbery_rate        = hit.robbery_rate;
        f.properties.sexual_assault_rate = hit.sexual_assault_rate;
        f.properties.violent_total_rate  = hit.violent_total_rate;
        f.properties.homicide_count      = hit.homicide_count;
        f.properties.country_iso         = hit.country;
      }
    }

    map.addSource("regions", { type: "geojson", data: geo });
    map.addLayer({
      id: "region-fill",
      type: "fill",
      source: "regions",
      paint: { "fill-color": fillExpression(currentMetric), "fill-opacity": 0.78 },
    });
    map.addLayer({
      id: "region-line",
      type: "line",
      source: "regions",
      paint: { "line-color": "#0f0f0f", "line-width": 0.4, "line-opacity": 0.6 },
    });

    // ----- Pin layer -----
    try {
      const ir = await fetch("/data/incidents.geojson");
      if (ir.ok) {
        const incidents = await ir.json();
        map.addSource("incidents", { type: "geojson", data: incidents });
        map.addLayer({
          id: "incident-pins",
          type: "circle",
          source: "incidents",
          paint: {
            "circle-radius": ["interpolate", ["linear"], ["zoom"], 4, 4, 6, 6, 9, 9],
            "circle-color": [
              "case",
              [">", ["coalesce", ["get", "victim_fatal"], 0], 0],
              "#9b2a2a", "#d65f1c",
            ],
            "circle-stroke-color": "#0f0f0f",
            "circle-stroke-width": 1,
            "circle-opacity": [
              "case",
              ["==", ["get", "confidence"], "HIGH"], 0.95,
              ["==", ["get", "confidence"], "MEDIUM"], 0.85,
              0.7,
            ],
          },
        });
        const ipop = new maplibregl.Popup({ closeButton: true, closeOnClick: true, maxWidth: "320px" });
        map.on("click", "incident-pins", (e) => {
          const f = e.features?.[0];
          if (!f) return;
          const p = f.properties as any;
          let sources: any[] = [];
          try { sources = JSON.parse(p.sources ?? "[]"); } catch {}
          const sourceLinks = sources.length
            ? sources.map((s: any) => `<a href="${s.url}" target="_blank" rel="noopener noreferrer">${s.outlet ?? "source"}</a>`).join(", ")
            : "—";
          const quote = sources[0]?.quote_snippet ?? "";
          const fatalBadge = (p.victim_fatal ?? 0) > 0
            ? `<span style="color:#9b2a2a;font-weight:600">FATAL</span> · ` : "";
          const html = `
            <div style="font-family:Inter,system-ui;font-size:12px;line-height:1.45;max-width:300px">
              <div style="font-weight:600">${p.city || "(unknown)"} · ${p.country}</div>
              <div style="color:#6b6b6b;margin-bottom:6px">
                ${fatalBadge}weapon: ${p.weapon ?? "?"} · victims: ${p.victim_count ?? "?"} · conf: ${p.confidence ?? "?"}
              </div>
              ${quote ? `<div style="font-style:italic;color:#0f0f0f;border-left:3px solid #9b2a2a;padding-left:8px;margin:6px 0">${quote}</div>` : ""}
              ${p.date_incident ? `<div style="color:#6b6b6b">Incident: ${p.date_incident}</div>` : ""}
              <div style="color:#6b6b6b">Source: ${sourceLinks}</div>
            </div>`;
          ipop.setLngLat((f.geometry as any).coordinates).setHTML(html).addTo(map);
        });
        map.on("mouseenter", "incident-pins", () => { map.getCanvas().style.cursor = "pointer"; });
        map.on("mouseleave", "incident-pins", () => { map.getCanvas().style.cursor = ""; });
      }
    } catch {}

    // Region hover popup.
    const popup = new maplibregl.Popup({ closeButton: false, closeOnClick: false });
    map.on("mousemove", "region-fill", (e) => {
      const f = e.features?.[0];
      if (!f) return;
      const p = f.properties as any;
      const fmt = new Intl.NumberFormat("en-GB", { maximumFractionDigits: 2 });
      const cfg = METRIC_CONFIG[currentMetric];
      const v = p[currentMetric];
      const html = `
        <div style="font-family:Inter,system-ui;font-size:12px;line-height:1.4">
          <div style="font-weight:600">${p.name ?? p.code}</div>
          <div style="color:#6b6b6b">${p.country_iso ?? "—"} · ${p.code}</div>
          <div style="margin-top:4px">
            ${cfg.label}: <b>${v !== null && v !== undefined ? fmt.format(v) : "—"}</b>
          </div>
        </div>`;
      map.getCanvas().style.cursor = "pointer";
      popup.setLngLat(e.lngLat).setHTML(html).addTo(map);
    });
    map.on("mouseleave", "region-fill", () => {
      map.getCanvas().style.cursor = "";
      popup.remove();
    });

    setLegend(currentMetric);
  });

  // Metric selector handler
  document.getElementById("metric-select")?.addEventListener("change", (e) => {
    const target = e.target as HTMLSelectElement;
    currentMetric = target.value as Metric;
    if (map.getLayer("region-fill")) {
      map.setPaintProperty("region-fill", "fill-color", fillExpression(currentMetric));
    }
    setLegend(currentMetric);
  });

  // Pin toggle
  document.getElementById("show-pins")?.addEventListener("change", (e) => {
    const t = e.target as HTMLInputElement;
    if (map.getLayer("incident-pins")) {
      map.setLayoutProperty("incident-pins", "visibility", t.checked ? "visible" : "none");
    }
  });
</script>
